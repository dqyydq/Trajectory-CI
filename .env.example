# Copy this file to .env and fill in your real keys.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
PRICING_CONFIG_PATH=config/pricing.example.yaml

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_observability
DASHBOARD_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_observability

# Optional gateway authentication. Leave empty for local development.
GATEWAY_API_KEYS=
DEFAULT_TENANT_ID=default

# Optional alerting. Alerts log warnings and can POST to ALERT_WEBHOOK_URL.
ALERTS_ENABLED=false
ALERT_WINDOW_MINUTES=5
ALERT_ERROR_RATE_THRESHOLD=0.2
ALERT_MIN_REQUESTS=10
ALERT_P95_LATENCY_MS=30000
ALERT_COST_SPIKE_MULTIPLIER=3.0
ALERT_MIN_COST_USD=1.0
ALERT_WEBHOOK_URL=